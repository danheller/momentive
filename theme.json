{
	"$schema": "https://schemas.wp.org/trunk/theme.json",
	"version": 3,
	"customTemplates": [
		{
			"name": "blank",
			"postTypes": ["page", "post"],
			"title": "Blank"
		},
		{
			"name": "no-title",
			"postTypes": ["page", "post"],
			"title": "No Title"
		}
	],
	"settings": {
		"appearanceTools": true,

		"color": {
			"defaultDuotone": false,
			"defaultGradients": false,
			"defaultPalette": false,

			"palette": [
				{
					"color": "#ffffff",
					"name": "White",
					"slug": "base"
				},
				{
					"color": "#000000",
					"name": "Black",
					"slug": "contrast"
				},
				{
					"color": "rgb(34, 34, 34)",
					"name": "Text",
					"slug": "text"
				},
				{
					"color": "#eeeeee",
					"name": "Neutral",
					"slug": "neutral"
				},
				{
					"color": "rgb(0, 120, 255)",
					"name": "Accent Blue",
					"slug": "primary"
				},
				{
					"color": "#C1E6F7",
					"name": "Light Blue",
					"slug": "light-accent"
				},
				{
					"color": "rgb(224, 243, 251)",
					"name": "Extra Light Blue",
					"slug": "extralight-accent"
				},
				{
					"color": "rgb(239, 249, 253)",
					"name": "Super Light Blue",
					"slug": "superlight-accent"
				},
				{
					"color": "#f26522",
					"name": "Orange",
					"slug": "secondary"
				},
				{
					"color": "rgb(20, 29, 60)",
					"name": "Dark Navy",
					"slug": "dark"
				},
				{
					"color": "rgb(110, 193, 228)",
					"name": "Brand Blue",
					"slug": "brand"
				},
				{
					"color": "#daf7fb",
					"name": "Aqua",
					"slug": "aqua"
				}
			],

			"gradients": [
				{
					"gradient": "linear-gradient(180deg, rgba(255,255,255,1) 0%, rgb(239,249,253) 100%)",
					"name": "White to Super Light Blue",
					"slug": "white-to-superlight"
				},
				{
					"gradient": "linear-gradient(90deg, rgb(226, 244, 252) 0%, rgb(238, 249, 253) 100%)",
					"name": "Horizontal Light Blue to Super Light Blue",
					"slug": "light-to-superlight-horizontal"
				},
				{
					"gradient": "linear-gradient(180deg, rgb(20,29,60) 30%, rgb(19,40,112) 100%)",
					"name": "Dark Navy",
					"slug": "dark-navy"
				}
			]
		},

		"custom": {
			"fontWeight": {
				"thin": 100,
				"extra-light": 200,
				"light": 300,
				"regular": 400,
				"medium": 500,
				"semi-bold": 600,
				"bold": 700,
				"extra-bold": 800,
				"black": 900
			},
			"lineHeight": {
				"body": 1.75,
				"heading": 1.1,
				"medium": 1.5,
				"one": 1
			},
			"spacing": {
				"gap": "2.5rem"
			},
			"slimSize": "40rem",
			"narrowSize": "48rem",
			"fittedSize": "57.5rem"
		},

		"layout": {
			"contentSize": "71.875rem",
			"wideSize": "108.125rem"
		},

		"shadow": {
			"defaultPresets": false,
			"presets": [
				{
					"name": "Soft",
					"shadow": "rgba(0, 0, 0, 0.35) 0 0 1.25rem 0",
					"slug": "soft"
				},
				{
					"name": "Diffuse",
					"shadow": "rgba(23, 42, 67, .15) 0 .625rem 1.875rem 0",
					"slug": "diffuse"
				},
				{
					"name": "Layered",
					"shadow": "-20px 80px 44px rgba(0, 0, 0, 0.01), -11px 61px 37px rgba(0, 0, 0, 0.02), -5px 27px 27px rgba(0, 0, 0, 0.04), -1px 7px 15px rgba(0, 0, 0, 0.05)",
					"slug": "layered"
				},
				{
					"name": "Card",
					"shadow": "rgba(0, 0, 0, 0.125) 0 0 0.75rem 0",
					"slug": "card"
				},
				{
					"name": "Card Large",
					"shadow": "rgba(0, 0, 0, 0.5) 0 0 1.5rem 0",
					"slug": "card-large"
				},
				{
					"name": "Solid",
					"shadow": "5px 5px 0 rgb(10, 10, 10, 1)",
					"slug": "solid"
				}
			]
		},

		"spacing": {
			"blockGap": true,
			"defaultSpacingSizes": false,
			"spacingSizes": [
				{
					"name": "X Small",
					"size": "1.5rem",
					"slug": "x-small"
				},
				{
					"name": "Small",
					"size": "clamp(1.875rem, 4vw, 2.5rem)",
					"slug": "small"
				},
				{
					"name": "Medium",
					"size": "clamp(2.5rem, 6vw, 3.75rem)",
					"slug": "medium"
				},
				{
					"name": "Large",
					"size": "clamp(3.125rem, 8vw, 5rem)",
					"slug": "large"
				},
				{
					"name": "X Large",
					"size": "clamp(3.75rem, 10vw, 6.25rem)",
					"slug": "x-large"
				}
			],
			"units": ["px", "em", "rem", "vh", "vw", "%"]
		},

		"typography": {
			"defaultFontSizes": false,
			"dropCap": false,
			"fluid": true,

			"fontFamilies": [
				{
					"fontFace": [
						{
							"fontDisplay": "swap",
							"fontFamily": "Figtree",
							"fontStretch": "normal",
							"fontStyle": "normal",
							"fontWeight": "100 900",
							"src": ["file:./assets/fonts/Figtree-Variable.woff2"]
						}
					],
					"fontFamily": "Figtree, sans-serif",
					"name": "Figtree",
					"slug": "primary"
				},
				{
					"fontFamily": "-apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, Oxygen-Sans, Ubuntu, Cantarell, 'Helvetica Neue', sans-serif",
					"name": "System Font",
					"slug": "system-font"
				}
			],

			"fontSizes": [
				{
					"fluid": false,
					"name": "X Small",
					"size": "0.75rem",
					"slug": "x-small"
				},
				{
					"fluid": false,
					"name": "Small",
					"size": "0.875rem",
					"slug": "small"
				},
				{
					"fluid": false,
					"name": "Regular",
					"size": "1rem",
					"slug": "regular"
				},
				{
					"name": "Medium",
					"slug": "medium",
					"size": "clamp(1rem, 0.95rem + 0.3vw, 1.125rem)"
				},
				{
					"name": "Large",
					"slug": "large",
					"size": "clamp(1.25rem, 1rem + 1vw, 1.5rem)"
				},
				{
					"name": "XL",
					"slug": "x-large",
					"size": "clamp(1.5rem, 3vw, 2rem)"
				},
				{
					"name": "XXL",
					"slug": "xx-large",
					"size": "clamp(1.75rem, 3.5vw, 2.5rem)"
				},
				{
					"name": "XXXL",
					"slug": "xxx-large",
					"size": "clamp(2rem, 4vw, 3rem)"
				},
				{
					"name": "Display",
					"slug": "display",
					"size": "clamp(2.5rem, 4.5vw, 3.5rem)"
				},
				{
					"name": "Display Large",
					"slug": "display-large",
					"size": "clamp(2.5rem, 5vw, 4rem)"
				}
			]
		},

		"useRootPaddingAwareAlignments": true
	},

	"styles": {
		"color": {
			"background": "var(--wp--preset--color--base)",
			"text": "var(--wp--preset--color--text)"
		},

		"typography": {
			"fontFamily": "var(--wp--preset--font-family--primary)",
			"fontSize": "var(--wp--preset--font-size--regular)",
			"fontWeight": "var(--wp--custom--font-weight--light)",
			"lineHeight": "var(--wp--custom--line-height--body)"
		},

		"spacing": {
			"blockGap": "var(--wp--custom--spacing--gap)",
			"padding": {
				"top": "0px",
				"right": "var(--wp--custom--spacing--gap)",
				"bottom": "0px",
				"left": "var(--wp--custom--spacing--gap)"
			}
		},

		"elements": {
			"heading": {
				"typography": {
					"fontWeight": "var(--wp--custom--font-weight--semi-bold)",
					"lineHeight": "var(--wp--custom--line-height--heading)"
				}
			},
			"h2": {
				"typography": {
					"fontSize": "var(--wp--preset--font-size--xxx-large)"
				}
			},
			"h3": {
				"typography": {
					"fontSize": "var(--wp--preset--font-size--xx-large)"
				}
			},
			"h4": {
				"typography": {
					"fontSize": "var(--wp--preset--font-size--large)"
				}
			},
			"h5": {
				"typography": {
					"fontSize": "var(--wp--preset--font-size--medium)"
				}
			},
			"h6": {
				"typography": {
					"fontSize": "var(--wp--preset--font-size--medium)"
				}
			},
			"link": {
				"color": {
					"text": "var(--wp--preset--color--secondary)"
				},
				"typography": {
					"textDecorationThickness": "1px",
					"textUnderlineOffset": "0.125em"
				}
			},
			"button": {
				"border": {
					"radius": "3rem"
				},
				"color": {
					"background": "var(--wp--preset--color--secondary)",
					"text": "var(--wp--preset--color--base)"
				},
				"spacing": {
					"padding": {
						"top": "0.75rem",
						"right": "1.5rem",
						"bottom": "0.75rem",
						"left": "1.5rem"
					}
				},
				"typography": {
					"fontSize": "var(--wp--preset--font-size--regular)",
					"fontWeight": "var(--wp--custom--font-weight--semi-bold)",
					"lineHeight": "var(--wp--custom--line-height--medium)"
				},
				":hover": {
					"color": {
						"background": "color-mix(in srgb, var(--wp--preset--color--secondary), black 20%)"
					}
				}
			},
			"caption": {
				"spacing": {
					"margin": {
						"top": "10px",
						"bottom": "0px"
					}
				},
				"typography": {
					"fontSize": "var(--wp--preset--font-size--small)"
				}
			}
		},

		"blocks": {
			"core/buttons": {
				"spacing": {
					"blockGap": "10px"
				}
			},
			"core/button": {
				"variations": {
					"outline": {
						"border": {
							"color": "currentColor",
							"style": "solid",
							"width": "1px"
						}
					}
				}
			},
			"core/code": {
				"color": {
					"background": "var(--wp--preset--color--contrast)",
					"text": "var(--wp--preset--color--base)"
				},
				"css": "& code {overflow-wrap: normal; overflow-x: scroll; tab-size: 4; white-space: pre !important;}",
				"spacing": {
					"padding": {
						"top": "var(--wp--custom--spacing--gap)",
						"right": "var(--wp--custom--spacing--gap)",
						"bottom": "var(--wp--custom--spacing--gap)",
						"left": "var(--wp--custom--spacing--gap)"
					}
				},
				"typography": {
					"fontSize": "var(--wp--preset--font-size--small)"
				}
			},
			"core/columns": {
				"spacing": {
					"blockGap": "2.5rem"
				}
			},
			"core/image": {
				"spacing": {
					"margin": {
						"top": "1.875rem",
						"right": "0",
						"bottom": "1.875rem",
						"left": "0"
					}
				}
			},
			"core/list": {
				"css": "&.is-style-no-disc {list-style-type: none; padding-left: 0;}",
				"spacing": {
					"padding": {
						"left": "var(--wp--custom--spacing--gap)"
					}
				}
			},
			"core/navigation": {
				"elements": {
					"link": {
						"typography": {
							"textDecoration": "none"
						}
					}
				}
			},
			"core/paragraph": {
				"css": ".has-background {padding: 20px 30px;}"
			},
			"core/post-template": {
				"spacing": {
					"blockGap": "var(--wp--preset--spacing--medium)"
				}
			},
			"core/pullquote": {
				"border": {
					"color": "var(--wp--preset--color--contrast)",
					"style": "solid",
					"width": "1px"
				},
				"css": "& p {margin: 0;}",
				"elements": {
					"cite": {
						"typography": {
							"fontSize": "var(--wp--preset--font-size--x-small)",
							"fontStyle": "inherit"
						}
					}
				},
				"spacing": {
					"padding": {
						"top": "var(--wp--custom--spacing--gap)",
						"right": "var(--wp--custom--spacing--gap)",
						"bottom": "var(--wp--custom--spacing--gap)",
						"left": "var(--wp--custom--spacing--gap)"
					}
				},
				"typography": {
					"fontSize": "var(--wp--preset--font-size--medium)",
					"lineHeight": "var(--wp--custom--line-height--medium)"
				}
			},
			"core/quote": {
				"border": {
					"color": "var(--wp--preset--color--contrast)",
					"style": "solid",
					"width": "1px"
				},
				"css": "& p {margin: 0;}",
				"elements": {
					"cite": {
						"typography": {
							"fontSize": "var(--wp--preset--font-size--x-small)",
							"fontStyle": "inherit"
						}
					}
				},
				"spacing": {
					"padding": {
						"top": "var(--wp--custom--spacing--gap)",
						"right": "var(--wp--custom--spacing--gap)",
						"bottom": "var(--wp--custom--spacing--gap)",
						"left": "var(--wp--custom--spacing--gap)"
					}
				}
			},
			"core/separator": {
				"border": {
					"color": "currentColor",
					"radius": "0",
					"style": "solid",
					"width": "1px 0 0"
				},
				"css": ":not(.is-style-wide):not(.is-style-dots) {width: 100px;}"
			},
			"core/site-title": {
				"elements": {
					"link": {
						"typography": {
							"textDecoration": "none"
						}
					}
				}
			},
			"core/social-links": {
				"css": ".is-style-outline .wp-block-social-link {background-color: transparent; border: 1px solid currentColor;}",
				"spacing": {
					"blockGap": "10px"
				}
			},
			"core/spacer": {
				"spacing": {
					"margin": {
						"top": "0"
					}
				}
			},
			"core/table": {
				"css": "th {border-color: var(--wp--preset--color--contrast) !important;} & td {border-color: var(--wp--preset--color--contrast) !important;}",
				"typography": {
					"fontSize": "var(--wp--preset--font-size--small)"
				}
			},
			"core/template-part": {
				"spacing": {
					"margin": {
						"top": "0"
					}
				}
			}
		}
	},

	"templateParts": [
		{
			"area": "header",
			"name": "header",
			"title": "Header"
		},
		{
			"area": "footer",
			"name": "footer",
			"title": "Footer"
		},
		{ "name": "megamenu-products", "title": "Megamenu: Products", "area": "uncategorized" },
		{ "name": "megamenu-solutions", "title": "Megamenu: Solutions", "area": "uncategorized" },
		{ "name": "megamenu-who-we-serve", "title": "Megamenu: Who We Serve", "area": "uncategorized" },
		{ "name": "megamenu-why-momentive", "title": "Megamenu: Why Momentive", "area": "uncategorized" },
		{ "name": "megamenu-resources", "title": "Megamenu: Resources", "area": "uncategorized" }
	]
}
